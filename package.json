{
  "name": "viktordemydov.com",
  "type": "module",
  "version": "1.4.0",
  "description": "Personal website of Viktor Demydov",
  "scripts": {
    "build": "eleventy",
    "watch": "eleventy --watch",
    "serve": "eleventy --serve",
    "start": "eleventy --serve",
    "debug": "DEBUG=* eleventy",
    "build:cv": "'/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --headless=new --disable-gpu --no-pdf-header-footer --user-data-dir=\"$(mktemp -d)\" --print-to-pdf=Viktor-Demydov-CV.pdf \"file://$PWD/cv/cv.html\""
  },
  "author": "Viktor Demydov",
  "license": "MIT",
  "main": ".eleventy.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VicD129/viktordemydov.com.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/VicD129/viktordemydov.com/issues"
  },
  "homepage": "https://github.com/VicD129/viktordemydov.com#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5"
  }
}
